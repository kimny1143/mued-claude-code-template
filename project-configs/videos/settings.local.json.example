{
  "permissions": {
    "allow": [
      "Edit(*)",
      "Write(*)",
      "Bash(git add *)",
      "Bash(git commit *)",
      "Bash(git checkout *)",
      "Bash(git branch *)",
      "Bash(git push *)",
      "Bash(git pull *)",
      "Bash(git merge *)",
      "Bash(git stash *)",
      "Bash(git diff *)",
      "Bash(git log *)",
      "Bash(git status *)",
      "Bash(git worktree *)",
      "Bash(git blame *)",
      "Bash(npm run *)",
      "Bash(npm install *)",
      "Bash(npx *)",
      "Bash(pnpm *)",
      "Bash(node *)",
      "Bash(gh pr *)",
      "Bash(gh api *)",
      "Bash(gh run list *)",
      "Bash(gh run view *)",
      "Bash(ls *)",
      "Bash(mkdir *)",
      "Bash(cp *)",
      "Bash(mv *)",
      "Bash(rm *)",
      "Bash(cat *)",
      "Bash(wc *)",
      "Bash(head *)",
      "Bash(tail *)",
      "Bash(tree *)",
      "Bash(chmod *)",
      "WebSearch",
      "WebFetch(domain:github.com)",
      "mcp__claude-peers__send_message",
      "mcp__claude-peers__set_summary",
      "mcp__claude-peers__list_peers",
      "mcp__claude-peers__check_messages"
    ],
    "deny": [
      "Bash(git push * main)",
      "Bash(git push --force *)",
      "Bash(git reset --hard *)",
      "Bash(rm -rf /)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "/path/to/your/project/.claude/hooks/block-main-push.sh"
          }
        ]
      }
    ]
  }
}
